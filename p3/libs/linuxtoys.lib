## LinuxToys base shell library

# Unified message handler
_msg() {
    local type="$1"
    local text="$2"
    local title="${3:-LinuxToys}"

    if [[ "$DISABLE_ZENITY" == "1" ]]; then
        echo "$text"
        return 0
    fi

    case "$type" in
        info)    zenity --info --text "$text" --width 360 --height 300 ;;
        warning) zenity --warning --text "$text" --width 360 --height 300 ;;
        error)   zenity --error --title "$title" --text "$text" --width 360 --height 300 ;;
        *)       echo "$text" ;;
    esac
}
zeninf() { _msg info "$1"; }
zenwrn() { _msg warning "$1"; }
fatal() {
    _msg error "$1" "Fatal Error"
    exit 1
}
nonfatal() {
    _msg error "$1" "Error"
    return 1
}

# sourcing
sysdetect() {
    source /etc/os-release || fatal "Failed to fetch OS information"
}
summon_helpers() {
    source "$SCRIPT_DIR/libs/helpers.lib" || fatal "Helpers library not found"
}
summon_optimizers() {
    source "$SCRIPT_DIR/libs/optimizers.lib" || fatal "Optimizers library not found"
}

# sudo handler
sudo_rq() {
    [ -f "$SCRIPT_DIR/libs/zpass.sh" ] || fatal "Unable to set askpass"
    export SUDO_ASKPASS="$SCRIPT_DIR/libs/zpass.sh"
    # Check if already authorized
    if sudo -n true 2>/dev/null || [ -f /tmp/linuxtoys_sudo_validated ]; then
        [ -n "$LINUXTOYS_CHECKLIST" ] && touch /tmp/linuxtoys_sudo_validated
        return 0
    fi

    # CLI mode
    if [[ "$DISABLE_ZENITY" == "1" ]]; then
        local max_attempts=3
        local attempts=0

        while (( attempts < max_attempts )); do
            read -rsp "Password: " _pass
            echo
            if echo "${_pass}" | sudo -S -v &>/dev/null; then
                [ -n "$LINUXTOYS_CHECKLIST" ] && touch /tmp/linuxtoys_sudo_validated
                return 0
            fi
            ((attempts++))
            echo "❌ Wrong password. Attempts: ${attempts}/${max_attempts}."
        done
        fatal "❌ Wrong password or sudo failed (max attempts reached)."
    fi

    # GUI mode
    if command -v sudo-rs &>/dev/null; then
        _pass=$(zenity --password --title="LinuxToys")
        echo "${_pass}" | sudo-rs -Sv
    else
        sudo -Av
    fi

    if [ "$(sudo whoami)" = "root" ]; then
        [ -n "$LINUXTOYS_CHECKLIST" ] && touch /tmp/linuxtoys_sudo_validated
        return 0
    else
        fatal "Wrong password. Do you have sudo?"
    fi
}

# Package Management
_install_() {
    sysdetect
    [[ -z "$_packages" ]] && return 0

    # OSTree handling
    if command -v rpm-ostree &>/dev/null; then
        local _to_install=()
        for pkg in "${_packages[@]}"; do
            rpm -qi "$pkg" &>/dev/null || _to_install+=("$pkg")
        done
        if [[ ${#_to_install[@]} -gt 0 ]]; then
            for item in "${_to_install[@]}"; do
                sudo rpm-ostree install -yA "$item"
            done
        fi
        unset _packages
        return 0
    fi

    # Standard Package Managers
    case "${ID_LIKE:-$ID}" in
        *debian*|*ubuntu*)
            for pak in "${_packages[@]}"; do
                if ! dpkg -s "$pak" &>/dev/null; then
                    sudo apt install -y "$pak"
                    echo "pkg $pak" >> /tmp/linuxtoys/transmap
                fi
            done
            ;;
        *arch*|*artix*|*archlinux*|*cachyos*)
            for pak in "${_packages[@]}"; do
                pacman -Qi "$pak" &>/dev/null && continue

                if pacman -Ss "$pak" | grep -q "$pak"; then
                    sudo pacman -S --noconfirm "$pak"
                    echo "pkg $pak" >> /tmp/linuxtoys/transmap
                else
                    if zenity --question --title "Installer" --text "$msg305" --height=300 --width=300; then
                        if ! command -v paru &>/dev/null; then
                            if pacman -Ss paru | grep -q paru; then
                                sudo pacman -S --noconfirm paru
                            else
                                sudo pacman -S --needed base-devel
                                cd $HOME
                                git clone https://aur.archlinux.org/paru.git
                                cd paru
                                makepkg -si
                            fi
                        fi
                        paru -S -a --noconfirm --skipreview "$pak"
                        echo "pkg $pak" >> /tmp/linuxtoys/transmap
                    else
                        return 1
                    fi
                fi
            done
            ;;
        *rhel*|*fedora*|*centos*)
             for pak in "${_packages[@]}"; do
                if ! rpm -qi "$pak" &>/dev/null; then
                    sudo dnf in -y "$pak"
                    echo "pkg $pak" >> /tmp/linuxtoys/transmap
                fi
            done
            ;;
        *suse*)
            for pak in "${_packages[@]}"; do
                if ! rpm -qi "$pak" &>/dev/null; then
                    sudo zypper in -y "$pak"
                    echo "pkg $pak" >> /tmp/linuxtoys/transmap
                fi
            done
            ;;
        *solus*)
            for pak in "${_packages[@]}"; do
                if ! { eopkg list-installed | grep -q "$pak"; }; then
                    sudo eopkg install -y "$pak"
                    echo "pkg $pak" >> /tmp/linuxtoys/transmap
                fi
            done
            ;;
    esac
    unset _packages
}

_flatpak_() {
    if ! which flatpak &>/dev/null || ! flatpak remote-list | grep -q flathub; then
        summon_helpers
        sudo_rq
        flatpak_in_lib
    fi
    [[ -z "$_flatpaks" ]] && return 0
    local flatpak_scope="--user"
    if flatpak remote-list --system 2>/dev/null | grep -q flathub && \
       ! flatpak remote-list --user 2>/dev/null | grep -q flathub; then
        flatpak_scope="--system"
    fi
    for flat in "${_flatpaks[@]}"; do
        flatpak install --or-update "$flatpak_scope" --noninteractive flathub "$flat"
        echo "flatpak $flat" >> /tmp/linuxtoys/transmap
    done
    unset _flatpaks
}

# --- Utils ---
_lang_() {
    local lang="${LANG:0:2}"
    local available=" am ar bn cs de el en es fa fi fr he hi id it ja ko ms nl pl pt ru sv sw ta th tl tr uk ur vi zh bg bs da hr hu is no sk sl sr nb az lv ga ne my sq tg uz hy ka km lo mn ro et lt "

    if [[ "$available" == *" $lang "* ]]; then
        langfile="$lang"
    else
        langfile="en"
    fi
    source "$SCRIPT_DIR/libs/lang/${langfile}.lib"
}

# --- System Detection ---
is_arch() sysdetect && { [[ ("$ID" =~ "arch" || "$ID" == "artix" || "$ID_LIKE" =~ "arch") && "$ID" != "cachyos" ]]; }
is_cachy() sysdetect && { [[ "$ID" == "cachyos" ]]; }
is_fedora() sysdetect && { [[ ("$ID" == "fedora" || "$ID" == "rhel" || "$ID_LIKE" =~ "fedora" || "$ID_LIKE" =~ "rhel" || "$ID_LIKE" =~ "centos") ]] && ! command -v rpm-ostree &>/dev/null; }
is_ostree() sysdetect && { [[ ("$ID" == "fedora" || "$ID" == "rhel" || "$ID_LIKE" =~ "fedora" || "$ID_LIKE" =~ "rhel" || "$ID_LIKE" =~ "centos") ]] && command -v rpm-ostree &>/dev/null; }
is_debian() sysdetect && { [[ "$ID" == "debian" || "$ID" == "ubuntu" || "$ID_LIKE" =~ "debian" || "$ID_LIKE" =~ "ubuntu" ]]; }
is_ubuntu() sysdetect && { [[ "$ID" == "ubuntu" || "$ID_LIKE" =~ "ubuntu" ]]; }
is_suse() sysdetect && { [[ "$ID" == "suse" || "$ID" == "opensuse" || "$ID_LIKE" =~ "suse" ]]; }
is_solus() sysdetect && { [[ "$ID" == "solus" ]]; }

# GPU detection
is_nvidia() {
    local nvidiaGPU=$(lspci | grep -i 'nvidia')
    if [[ -n "$nvidiaGPU" ]]; then
        return 0
    else
        return 1
    fi
}
is_intel() {
    local intelGPU=$(lspci | grep -Ei 'vga|3d' | grep -Ei 'intel')
    if [[ -n "$intelGPU" ]]; then
        if echo "$intelGPU" | grep -Eqi 'battlemage|alchemist'; then
            intel_arc="yes"
        fi
        return 0
    else
        return 1
    fi
}
is_amd() {
    local amdGPU=$(lspci | grep -Ei '(amd|radeon|rx|amdgpu)')
    if [[ -n "$amdGPU" ]]; then
        return 0
    else
        return 1
    fi
}

# file preparations
prep_edit() {
    for target in "$@"; do
        { cp -r "$target" "$target".bak || sudo cp -r "$target" "$target".bak; } || fatal "Failed to create backup: $target"
        echo "edited $target" >> /tmp/linuxtoys/transmap
    done
}
prep_create() {
    for target in "$@"; do
        { mkdir -p "$(dirname "$target")" && touch "$target"; } \
        || { sudo mkdir -p "$(dirname "$target")" && sudo touch "$target"; } \
        || fatal "Failed to create: $target"
        echo "created $target" >> /tmp/linuxtoys/transmap
    done
}
prep_rm() {
    for target in "$@"; do
        { mv "$target" "$target".bak || sudo mv "$target" "$target".bak; } || fatal "Failed to create backup: $target"
        echo "removed $target" >> /tmp/linuxtoys/transmap
    done
}
prep_tmp() {
    { mkdir -p /tmp/linuxtoys && cd /tmp/linuxtoys; } || fatal "Failed to create tempdir"
    LT_TEMPDIR="/tmp/linuxtoys"
}
prep_dir() {
    for dir in "$@"; do
        if [ ! -d "$dir" ]; then
            { mkdir -p "$dir" || sudo mkdir -p "$dir"; } || fatal "Failed to create $dir"
            echo "created $dir" >> /tmp/linuxtoys/transmap
        fi
    done
}

# bootloader update
bootloader_upd() {
    if ! is_ostree; then
        if is_fedora || is_suse; then
            sudo grub2-mkconfig -o /boot/grub2/grub.cfg || fatal "Unable to update bootloader"
            echo "updated bootloader" >> /tmp/linuxtoys/transmap
        elif is_arch || is_cachy; then
            sudo grub-mkconfig -o /boot/grub/grub.cfg || fatal "Unable to update bootloader"
            echo "updated bootloader" >> /tmp/linuxtoys/transmap
        elif is_debian || is_ubuntu; then
            sudo update-grub || fatal "Unable to update bootloader"
            echo "updated bootloader" >> /tmp/linuxtoys/transmap
        elif is_solus; then
            { sudo clr-boot-manager update || sudo grub-mkconfig -o /boot/grub/grub.cfg; } || fatal "Unable to update bootloader"
            echo "updated bootloader" >> /tmp/linuxtoys/transmap
        fi
    else
        return 0
    fi
}
initramfs_upd() {
    if is_debian; then
        sudo update-initramfs -u || fatal "Failed to update initramfs"
        echo "updated initramfs" >> /tmp/linuxtoys/transmap
    elif is_arch || is_cachy; then
        sudo mkinitcpio -P || fatal "Failed to update mkinitcpio"
        echo "updated initramfs" >> /tmp/linuxtoys/transmap
    elif is_fedora || is_suse; then
        sudo dracut -f --regenerate-all || fatal "Failed to update dracut"
        echo "updated initramfs" >> /tmp/linuxtoys/transmap
    fi
}
kargs_upd() {
    for arg in "$@"; do
        sudo rpm-ostree kargs --append="$arg" || fatal "Failed to update rpm-ostree kargs"
        echo "updated kargs $arg" >> /tmp/linuxtoys/transmap
    done
}

# systemd service operations
sysd_enable() {
    for svc in "$@"; do
        sudo systemctl enable "$svc" || fatal "Failed to enable service $svc"
        echo "sysd enabled $svc" >> /tmp/linuxtoys/transmap
    done
}
sysd_disable() {
    for svc in "$@"; do
        sudo systemctl disable "$svc" || fatal "Failed to disable service $svc"
        echo "sysd disabled $svc" >> /tmp/linuxtoys/transmap
    done
}
sysd_start() {
    for svc in "$@"; do
        sudo systemctl start "$svc" || fatal "Failed to start service $svc"
        echo "sysd started $svc" >> /tmp/linuxtoys/transmap
    done
}
sysd_stop() {
    for svc in "$@"; do
        sudo systemctl stop "$svc" || fatal "Failed to stop service $svc"
        echo "sysd stopped $svc" >> /tmp/linuxtoys/transmap
    done
}